# Google Docs API Configuration
GOOGLE_DOCS_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CREDENTIALS_JSON=/path/to/credentials.json

# Slack API Configuration
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Elasticsearch Configuration (Phase 2)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_password_here

# SLURM Configuration (Phase 2)
SLURM_SACCT_COMMAND=/usr/bin/sacct

# ServiceNow Configuration (Phase 3)
SERVICENOW_INSTANCE=your_instance.service-now.com
SERVICENOW_USERNAME=your_username
SERVICENOW_PASSWORD=your_password

# Reporter Configuration
CACHE_DIR=./cache
CACHE_DB=./cache/cache.db
LOG_LEVEL=INFO
