# servers.config - MCP Server Registry
# Format: server_name:relative/path/to/server.py
# Servers listed here are automatically discovered and loaded by the CLI
# Uncomment Phase 2 and Phase 3 servers as they become available

# ===== PHASE 1: MVP (Google Docs + Slack) =====
google_docs:servers/google_docs_server.py
slack:servers/slack_server.py

